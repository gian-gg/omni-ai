APP_NAME=omni-api
ENV=dev
LOG_LEVEL=INFO

# Supabase project settings.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Legacy fallback if you are still using the old key format.
# SUPABASE_ANON_KEY=eyJ...
SUPABASE_AUDIENCE=authenticated

# Override these only if you do not want them derived from SUPABASE_URL.
# SUPABASE_ISSUER=https://your-project-ref.supabase.co/auth/v1
# SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

# Supabase Postgres connection for SQLAlchemy and Alembic.
DATABASE_URL=postgresql+psycopg://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# Required for live LLM responses.
LLM_API_KEY=

# DeepSeek defaults.
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# Optional behavior override.
SYSTEM_PROMPT=You are a helpful, concise assistant.

# Required for note embeddings (Gemini text-embedding-004, free tier).
GEMINI_API_KEY=
# Optional overrides.
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com
